datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  ADMIN
  SUPER_ADMIN
}

model Admin {
  id        String   @id @default(uuid())
  username  String
  email     String   @unique
  password  String
  role      Role     @default(ADMIN)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Service {
  id           String   @id @default(uuid())
  slug         String   @unique
  icon         String
  title        String
  description  String   @db.Text
  image        String
  benefits     Json     // Array of strings representing service benefits
  status       Boolean  @default(true)
  displayOrder Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model TeamMember {
  id             String   @id @default(uuid())
  name           String
  role           String
  bio            String   @db.Text
  photo          String
  objectPosition String   @default("center")
  transform      String?
  transformHover String?
  instagram      String?
  twitter        String?
  linkedin       String?
  displayOrder   Int      @default(0)
  status         Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Message {
  id        String   @id @default(uuid())
  name      String
  email     String
  phone     String
  whatsapp  String?
  message   String   @db.Text
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ActivityLog {
  id         String   @id @default(uuid())
  action     String
  details    String?  @db.Text
  adminEmail String
  createdAt  DateTime @default(now())
}

model SiteSetting {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String   @db.Text
  updatedAt DateTime @updatedAt
}
